{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-push-test.js",
            "if": "Bash(git push*)",
            "timeout": 120,
            "statusMessage": "Running npm test before push..."
          }
        ]
      }
    ]
  }
}
