# OpenAI-compatible API provider
# 阿里百炼通义千问: AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1, AI_MODEL=qwen-turbo
# DeepSeek: AI_BASE_URL=https://api.deepseek.com, AI_MODEL=deepseek-chat
# OpenRouter free: AI_BASE_URL=https://openrouter.ai/api/v1, AI_MODEL=openai/gpt-oss-20b:free
AI_PROVIDER=aliyun-bailian
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-turbo
AI_API_KEY=sk-your-key-here

# 轻量上下文记忆
MEMORY_ENABLED=true
SAVE_RAW_MESSAGES=true
MAX_CONVERSATIONS=100
CHAT_CONTEXT_MESSAGES=4
SENTRY_CONTEXT_MESSAGES=3
MEMORY_REVIEW_EVERY=4
MAX_MEMORY_ITEMS=80
MAX_INBOX_ITEMS=30
MEMORY_CONTEXT_ITEMS=10
SUMMARY_MAX_CHARS=1200
SUMMARY_UPDATE_EVERY=10
ALLOW_HIGH_SENSITIVITY_MEMORY=false
